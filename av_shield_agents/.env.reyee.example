# Reyee / Ruijie Cloud adapter — environment variables
# Copy the relevant lines into your project .env (which is gitignored).

# --- Required ---
REYEE_USER=you@example.com
REYEE_PASS=your-portal-password

# --- Optional (sensible defaults shown) ---
# Run the browser headless (1) or visible (0)
REYEE_HEADLESS=1
# Where the persistent Playwright session (auth cookies) is stored.
# This file is gitignored (storage_state*.json).
REYEE_STORAGE_STATE=storage_state_reyee.json
# Point at a specific Chromium binary instead of Playwright's bundled one.
# Leave empty in normal setups (after `playwright install chromium`).
REYEE_CHROMIUM_PATH=
# HARD SAFETY GATE for destructive actions (reboot_port / reboot_switch).
# Writes are refused unless this is 1 AND the call passes confirm=True.
# Keep this 0 until you are ready to act on real equipment.
REYEE_ALLOW_WRITES=0
